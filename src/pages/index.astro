---
import BaseLayout from "../layouts/BaseLayout.astro";
import ShapeBg from "../components/ShapeBg.astro";

const doors = [
  {
    url: "/stories",
    name: "看真事儿",
    subtitle: "我自己用 AI 撞出来的真实经历",
    emoji: "🌱",
    doorBg: "bg-flame",
    text: "text-cream",
    interiorBg: "bg-gradient-to-b from-mint to-[#8AD5B5]",
    floorBg: "bg-[#6BC799]",
    particleBg: "bg-cream",
    knobBg: "bg-mint",
    label: "01",
  },
  {
    url: "/basics",
    name: "扫个盲",
    subtitle: "一句话讲懂一个概念",
    emoji: "📖",
    doorBg: "bg-sky",
    text: "text-violet",
    interiorBg: "bg-gradient-to-b from-[#FFD89E] to-flame-soft",
    floorBg: "bg-[#F19B70]",
    particleBg: "bg-cream",
    knobBg: "bg-flame",
    label: "02",
  },
  {
    url: "/recipes",
    name: "抄两招",
    subtitle: "亲测好用的 skills 和 prompt",
    emoji: "🧰",
    doorBg: "bg-violet",
    text: "text-cream",
    interiorBg: "bg-gradient-to-b from-flame-soft to-flame",
    floorBg: "bg-[#D9482E]",
    particleBg: "bg-cream",
    knobBg: "bg-flame",
    label: "03",
  },
  {
    url: "/picks",
    name: "瞧瞧外面",
    subtitle: "值得花 10 分钟的精选",
    emoji: "✨",
    doorBg: "bg-mint",
    text: "text-violet",
    interiorBg: "bg-gradient-to-b from-ink to-violet-deep",
    floorBg: "bg-violet",
    particleBg: "bg-cream",
    knobBg: "bg-violet-deep",
    label: "04",
  },
];
---

<BaseLayout>
  <!-- HERO -->
  <section class="relative">
    <ShapeBg />
    <div class="relative max-w-6xl mx-auto px-6 pt-20 pb-20 md:pt-28 md:pb-24">
      <p class="text-sm font-medium text-flame mb-6 tracking-wide">
        ✦ 一个慢慢长的小角落
      </p>
      <h1 class="font-display font-extrabold text-violet text-[clamp(3rem,9vw,7rem)] leading-[0.95] tracking-tight mb-8">
        把 AI<br/>
        <span class="relative inline-block">
          用起来
          <svg
            class="absolute -bottom-3 left-0 w-full"
            viewBox="0 0 300 20"
            preserveAspectRatio="none"
          >
            <path
              d="M5 15 Q 80 2 150 12 T 295 8"
              stroke="#FF6B47"
              stroke-width="5"
              stroke-linecap="round"
              fill="none"
            />
          </svg>
        </span>
        <br/>
        的小角落。
      </h1>
      <p class="max-w-2xl text-lg md:text-xl text-ink/75 leading-relaxed mb-10">
        这里不是 AI 教学网站，也不是大佬的修炼圣地。
        我把自己学 AI 路上真实发生过的事、捡到的 Prompt、用法和困惑慢慢攒在这儿——
        来串个门，挑你想看的看，能用上就拿走。
      </p>

      <div class="flex flex-wrap gap-3">
        <a href="#rooms" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-violet text-cream font-medium hover:bg-violet-deep transition-colors">
          推开四扇门看看
          <span aria-hidden="true">↓</span>
        </a>
        <a href="/about" class="inline-flex items-center gap-2 px-6 py-3 rounded-full border-2 border-violet text-violet font-medium hover:bg-violet hover:text-cream transition-colors">
          这里是谁建的？
        </a>
      </div>
    </div>
  </section>

  <!-- DOORS -->
  <section id="rooms" class="relative bg-cream py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-end justify-between mb-14 flex-wrap gap-4">
        <div>
          <p class="text-sm font-medium text-flame mb-3">✦ 四道门</p>
          <h2 class="font-display font-extrabold text-violet text-4xl md:text-5xl">
            推一扇<br class="md:hidden"/>进去看看。
          </h2>
        </div>
        <p class="text-ink/70 max-w-md">
          没有学习路径、没有打卡。<br/>每扇门里都是各自独立的小天地。
        </p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 max-w-5xl mx-auto">
        {doors.map((d) => (
          <a href={d.url} class="group block max-w-[220px] mx-auto w-full">
            <div class="door-stage relative aspect-[2/3.2]">

              {/* === INTERIOR WORLD (behind the door) === */}
              <div class={`absolute inset-0 rounded-t-[3rem] overflow-hidden ${d.interiorBg}`}>
                {/* floor band — gives 3D sense of "a room" */}
                <div class={`absolute left-0 right-0 bottom-0 h-[30%] ${d.floorBg}`}
                     style="clip-path: polygon(0 18%, 100% 0, 100% 100%, 0 100%);">
                </div>

                {/* atmosphere particles */}
                <div class="absolute inset-0 pointer-events-none">
                  <div class={`door-particle absolute top-[18%] left-[22%] w-1.5 h-1.5 rounded-full ${d.particleBg} opacity-70`}></div>
                  <div class={`door-particle absolute top-[12%] right-[28%] w-1 h-1 rounded-full ${d.particleBg} opacity-60`}></div>
                  <div class={`door-particle absolute top-[28%] right-[18%] w-2 h-2 rounded-full ${d.particleBg} opacity-50`}></div>
                  <div class={`door-particle absolute top-[42%] left-[15%] w-1 h-1 rounded-full ${d.particleBg} opacity-60`}></div>
                  <div class={`door-particle absolute top-[8%] left-[48%] w-1.5 h-1.5 rounded-full ${d.particleBg} opacity-75`}></div>
                </div>

                {/* the world's signature element (the "occupant") */}
                <div class="absolute inset-x-0 top-[32%] flex justify-center">
                  <span class="door-interior-emoji text-[6rem] md:text-[8rem] leading-none">
                    {d.emoji}
                  </span>
                </div>

                {/* subtle inner shadow at top — implies a ceiling */}
                <div
                  class="absolute inset-x-0 top-0 h-12 pointer-events-none"
                  style="background: linear-gradient(180deg, rgba(0,0,0,0.18), transparent);"
                ></div>
              </div>

              {/* === LIGHT WEDGE spilling outward from the open doorway === */}
              <div class="door-light-wedge absolute -right-8 top-[15%] w-24 h-[70%] pointer-events-none"></div>

              {/* === DOOR PANEL === */}
              <div class={`door-panel absolute inset-0 ${d.doorBg} ${d.text} rounded-t-[3rem] overflow-hidden`}>

                {/* room number badge */}
                <div class="absolute top-5 left-5 text-[10px] font-mono opacity-50 tracking-[0.25em]">
                  NO.{d.label}
                </div>

                {/* inner panel border (door detailing) */}
                <div class="absolute inset-4 border border-current opacity-15 rounded-[2rem] pointer-events-none"></div>
                <div class="absolute inset-7 border-t border-current opacity-10 pointer-events-none"></div>

                {/* center: name + subtitle */}
                <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-3">
                  <h3 class={`font-display font-extrabold text-2xl md:text-3xl tracking-tight leading-tight ${d.text}`}>
                    {d.name}
                  </h3>
                  <p class={`text-sm md:text-base mt-3 opacity-70 ${d.text}`}>
                    {d.subtitle}
                  </p>
                </div>

                {/* PROMINENT KNOB — color hints at what's inside === */}
                <div class={`door-knob-ring absolute right-5 top-1/2 -translate-y-1/2 w-6 h-6 rounded-full ${d.knobBg} flex items-center justify-center`}>
                  <div class="w-2 h-2 rounded-full bg-white/75"></div>
                </div>

                {/* bottom decoration (kick plate hint) */}
                <div class="absolute left-6 right-6 bottom-6 h-px bg-current opacity-20"></div>
                <div class="absolute left-8 right-8 bottom-4 h-px bg-current opacity-10"></div>
              </div>
            </div>

            <div class="text-center mt-5 text-xs font-medium text-violet/55 group-hover:text-flame transition-colors duration-300">
              推门进 →
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT BANNER -->
  <section class="bg-cream pb-20 md:pb-28">
    <div class="max-w-3xl mx-auto px-6">
      <a
        href="/about"
        class="card-hover group block rounded-2xl bg-peach-deep px-6 py-5 relative overflow-hidden"
      >
        <div class="absolute -bottom-8 -right-6 w-32 h-32 rounded-full bg-flame/25 blur-2xl pointer-events-none"></div>
        <div class="relative flex items-center gap-4">
          <div class="text-3xl transition-transform duration-500 group-hover:rotate-12">
            👋
          </div>
          <div class="flex-1">
            <h3 class="font-display font-extrabold text-violet text-lg md:text-xl leading-tight">
              关于这里
            </h3>
            <p class="text-sm text-ink/70">
              Jojo 是谁、为什么会有这个小园地——都在里面。
            </p>
          </div>
          <div class="text-violet text-xl group-hover:translate-x-1 transition-transform duration-300">
            →
          </div>
        </div>
      </a>
    </div>
  </section>
</BaseLayout>
