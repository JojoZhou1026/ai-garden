---
import BaseLayout from "./BaseLayout.astro";

const { frontmatter } = Astro.props;
const displayDate =
  frontmatter.date instanceof Date
    ? frontmatter.date.toISOString().slice(0, 10)
    : String(frontmatter.date).slice(0, 10);
---

<BaseLayout title={`${frontmatter.title} · AI 学习小园地`} description={frontmatter.excerpt}>
  <article class="max-w-3xl mx-auto px-6 py-16 md:py-24">
    <a href="/" class="inline-block text-sm text-violet hover:text-flame mb-8 transition-colors">
      ← 回到小园地
    </a>

    <div class="flex flex-wrap items-center gap-3 mb-6">
      <span class="text-xs font-medium px-3 py-1 rounded-full bg-violet/10 text-violet">
        {frontmatter.category}
      </span>
      <span class="text-sm text-ink/55">{displayDate}</span>
      {frontmatter.author && (
        <span class="text-sm text-ink/55">· {frontmatter.author}</span>
      )}
    </div>

    <h1 class="font-display font-extrabold text-violet text-4xl md:text-5xl leading-[1.08] tracking-tight mb-8">
      <span class="text-4xl md:text-5xl mr-3">{frontmatter.emoji}</span>
      {frontmatter.title}
    </h1>

    {frontmatter.excerpt && (
      <p class="text-xl text-ink/75 leading-relaxed mb-10 border-l-4 border-flame pl-5">
        {frontmatter.excerpt}
      </p>
    )}

    <div class="prose-jojo">
      <slot />
    </div>

    {/* === 留言区 === */}
    <section class="mt-20 pt-10 border-t border-violet/15">
      <div class="rounded-3xl bg-cream p-6 md:p-8">
        <p class="text-xs font-medium text-flame tracking-widest uppercase mb-3">
          ✦ 留个言
        </p>
        <h3 class="font-display font-extrabold text-violet text-2xl md:text-3xl mb-2">
          想问点啥？想补点啥？
        </h3>
        <p class="text-sm text-ink/65 mb-6">
          关于这篇内容的问题、补充、不同意见、纠错都可以留在这里。每条 Jojo 都会看到，但不一定都回。
        </p>

        {/*
          后端：Cloudflare Pages Function（functions/api/submit.ts）+ Resend API。
          需要在 Cloudflare Pages 项目设置里配 RESEND_API_KEY 和 NOTIFY_EMAIL 两个 env var。
        */}
        <form id="comment-form" class="space-y-4">
          <input
            type="text"
            name="name"
            placeholder="叫你什么？（可以不填）"
            class="w-full px-4 py-3 rounded-xl bg-peach border border-transparent focus:border-violet focus:outline-none transition-colors text-ink placeholder:text-ink/40"
            maxlength="100"
          />

          <textarea
            name="message"
            required
            rows="4"
            placeholder="比如：这里我没看懂 / 我也踩过这个坑 / 这个地方可能有误……"
            class="w-full px-4 py-3 rounded-xl bg-peach border border-transparent focus:border-violet focus:outline-none transition-colors text-ink placeholder:text-ink/40 resize-none"
            maxlength="5000"
          ></textarea>

          {/* honeypot：人类看不见，机器人会填 → 我们拒掉 */}
          <input
            type="text"
            name="website"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
            style="position:absolute; left:-9999px; width:1px; height:1px; opacity:0; pointer-events:none;"
          />

          <input type="hidden" name="post" value={frontmatter.title} />

          <div class="flex items-center flex-wrap gap-3">
            <button
              type="submit"
              id="comment-submit"
              class="px-6 py-2.5 rounded-full bg-violet text-cream text-sm font-medium hover:bg-flame transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
            >
              发出 →
            </button>
          </div>

          <p id="comment-status" class="text-sm hidden" role="status" aria-live="polite"></p>
        </form>

        <script is:inline>
          (function () {
            const form = document.getElementById("comment-form");
            const btn = document.getElementById("comment-submit");
            const status = document.getElementById("comment-status");
            if (!form || !btn || !status) return;

            form.addEventListener("submit", async (e) => {
              e.preventDefault();
              btn.disabled = true;
              btn.textContent = "发送中……";
              status.className = "text-sm hidden";

              try {
                const fd = new FormData(form);
                const res = await fetch("/api/submit", {
                  method: "POST",
                  body: fd,
                });
                const data = await res.json().catch(() => ({}));

                if (res.ok && data && data.ok) {
                  status.textContent = "✅ 收到了！谢谢你写来。";
                  status.className = "text-sm text-violet font-medium";
                  form.reset();
                } else {
                  const msg = (data && data.error) || "没发出去，可以稍后再试。";
                  status.textContent = "⚠️ " + msg;
                  status.className = "text-sm text-flame font-medium";
                }
              } catch (err) {
                status.textContent = "⚠️ 网络出了点问题，可以稍后再试。";
                status.className = "text-sm text-flame font-medium";
              } finally {
                btn.disabled = false;
                btn.textContent = "发出 →";
              }
            });
          })();
        </script>
      </div>
    </section>

    {/* === 底部 CTA === */}
    <div class="mt-12 pt-6 border-t border-violet/10 flex flex-wrap items-center justify-between gap-3">
      <a href="/" class="text-sm text-violet hover:text-flame transition-colors">
        ← 回到小园地
      </a>
      <a href="/about" class="text-sm text-violet hover:text-flame transition-colors">
        关于这里 →
      </a>
    </div>
  </article>
</BaseLayout>
