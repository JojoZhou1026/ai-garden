---
// Decorative shapes layer — absolute-positioned, pointer-events-none
---

<div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
  <!-- top-right floating ball -->
  <div
    class="shape-blob absolute -top-10 -right-12 w-72 h-72 rounded-full bg-flame/30 blur-3xl"
  ></div>
  <!-- bottom-left soft violet halo -->
  <div
    class="shape-blob absolute bottom-0 -left-20 w-96 h-96 rounded-full bg-violet/20 blur-3xl"
  ></div>
  <!-- a tiny mint pill -->
  <div
    class="absolute top-1/3 right-1/4 w-16 h-6 rounded-full bg-mint rotate-12 opacity-80"
  ></div>
  <!-- a sky square tilted -->
  <div
    class="absolute top-2/3 right-12 w-12 h-12 bg-sky rotate-12 rounded-md opacity-90"
  ></div>
  <!-- wire grid svg -->
  <svg
    class="absolute top-16 right-4 w-40 h-40 opacity-50"
    viewBox="0 0 100 100"
    fill="none"
    stroke="currentColor"
    stroke-width="0.7"
  >
    <g class="text-violet">
      {Array.from({ length: 10 }).map((_, i) => (
        <line x1={i * 11} y1="0" x2={i * 11 + 20} y2="100" />
      ))}
      {Array.from({ length: 10 }).map((_, i) => (
        <line x1="0" y1={i * 11} x2="100" y2={i * 11 - 10} />
      ))}
    </g>
  </svg>
</div>
